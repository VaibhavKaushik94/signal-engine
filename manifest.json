{
  "manifest_version": 3,
  "name": "Signal Engine",
  "version": "1.0",
  "author": "Signal Engine Team",
  "description": "AI-powered social media feed filter for X, LinkedIn, and YouTube.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "http://localhost:11434/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Signal Engine Settings",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://x.com/*", 
        "*://*.twitter.com/*",
        "*://twitter.com/*",
        "*://*.linkedin.com/*",
        "*://linkedin.com/*",
        "*://*.youtube.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}